# Copy to .env (gitignored) and fill in real values.

# Shared Supabase Postgres connection string (pooler host)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Supabase project (for frontend + storage uploads)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# WhatsApp Cloud API (Meta developer app -> WhatsApp -> API setup)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Gemini API key for extraction / vision / clustering labels
GEMINI_API_KEY=
