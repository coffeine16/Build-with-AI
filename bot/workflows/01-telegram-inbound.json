    {
      "parameters": {
        "jsCode": "const m = $json.message || {};\nreturn [{ json: {\n  chat_id: String(m.chat?.id || ''),\n  text: m.text || m.caption || '',\n  media_type: 'text',\n  photo_base64: null,\n  audio_base64: null,\n  mime_type: null,\n  has_voice: !!m.voice,\n  voice_file_id: m.voice?.file_id || null,\n  has_photo: !!m.photo,\n  photo_file_id: m.photo ? m.photo[m.photo.length - 1].file_id : null,\n  lat: m.location?.latitude ?? null,\n  lng: m.location?.longitude ?? null,\n  location_text: null,\n  language_hint: m.from?.language_code || null,\n  channel: 'telegram',\n  citizen_key: String(m.chat?.id || ''),\n  channel_message_id: 'tg-' + String(m.message_id || ''),\n} }];"
      },
      "name": "Normalize Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1536,
        400
      ],
      "id": "w1-n2-normalize"
    },
    {
      "parameters": {
